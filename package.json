{
  "name": "realestate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lean": "./scripts/lean-dev.sh",
    "build": "pnpm build:app",
    "build:app": "tsc -p tsconfig.app.json && vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "prettier --check --no-error-on-unmatched-pattern package.json tsconfig.json tsconfig.app.json tsconfig.node.json .github/workflows/*.yml src/hooks/**/*.{ts,tsx} src/lib/**/*.{ts,tsx} src/stores/**/*.{ts,tsx} src/__tests__/**/*.{ts,tsx} && bash -n .codex/actions/_artifact_env.sh .codex/actions/setup_local_env.sh .codex/actions/run_frontend_checks.sh .codex/actions/run_rust_checks.sh .codex/scripts/run_verify_commands.sh scripts/release/*.sh",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:smoke:ui": "vitest run src/__tests__/smoke/AppReadiness.test.tsx src/__tests__/pages/Settings.test.tsx src/components/property/PropertyForm.test.tsx src/__tests__/hooks/usePhotos.test.ts src/__tests__/hooks/useExport.test.ts",
    "test:smoke": "pnpm test:smoke:ui && cargo test --manifest-path src-tauri/Cargo.toml test_full_property_lifecycle --tests --verbose && cargo test --manifest-path src-tauri/Cargo.toml test_generate_pdf_without_photos_for_minimal_template --lib --verbose && cargo test --manifest-path src-tauri/Cargo.toml test_generate_docx_ignores_missing_photo_files --lib --verbose",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "check:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib --tests --no-run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib --verbose",
    "test:rust:integration": "cargo test --manifest-path src-tauri/Cargo.toml --tests --verbose",
    "verify": "./.codex/scripts/run_verify_commands.sh",
    "clean:heavy": "./scripts/clean-heavy.sh",
    "clean:full": "./scripts/clean-full.sh",
    "size:report": "./scripts/report-sizes.sh",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major",
    "prepare": "husky",
    "commit": "cz",
    "commitlint": "commitlint",
    "git:guard:branch": "bash scripts/git/guard-branch.sh",
    "git:guard:no-main-push": "bash scripts/git/guard-no-main-push.sh",
    "git:guard:atomic": "bash scripts/git/guard-atomic.sh",
    "git:guard:generated": "bash scripts/git/guard-generated.sh",
    "git:guard:large-files": "bash scripts/git/guard-large-files.sh",
    "git:guard:secrets": "bash scripts/git/guard-secrets.sh",
    "git:guard:all": "pnpm git:guard:branch && pnpm git:guard:atomic && pnpm git:guard:generated && pnpm git:guard:large-files && pnpm git:guard:secrets",
    "git:commit:propose": "node scripts/git/propose-commit-message.mjs",
    "git:session:save": "bash scripts/git/session-save.sh",
    "git:session:resume": "bash scripts/git/session-resume.sh",
    "pr:notes": "bash scripts/git/generate-pr-notes.sh",
    "release:check:versions": "bash scripts/release/validate-version-sync.sh",
    "release:smoke:local": "bash scripts/release/smoke-local.sh",
    "perf:bundle": "node scripts/perf/bundle-report.mjs",
    "perf:build": "node scripts/perf/measure-build-time.mjs",
    "perf:assets": "bash scripts/perf/check-assets.sh",
    "perf:memory": "node --expose-gc scripts/perf/memory-smoke.mjs",
    "perf:summary": "node scripts/perf/summarize.mjs",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "lucide-react": "^0.563.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.4.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~6.0.2",
    "vite": "^7.0.4",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "@lhci/cli": "^0.15.1",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
